# Ascent Platform — Production-oriented configuration (real MCP, no simulation)

APP_ENV=development
APP_SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://ascent:ascent@postgres:5432/ascent

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333

# Temporal
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ascent-incident-queue

# LLM (required for agents)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_DEFAULT_MODEL=openrouter/free
LLM_REASONING_MODEL=openrouter/free
LLM_FALLBACK_MODEL=meta-llama/llama-3.1-8b-instruct
# NVIDIA NIM uses meta/... model ids (not openrouter-style meta-llama/...)
NVIDIA_NIM_MODEL=minimaxai/minimax-m2.7

# Feature flags — REAL MODE (no demos)
ENABLE_HITL=true
ENABLE_LLM_MOCK=false
SIMULATE_ENTERPRISE_TOOLS=false
ENABLE_GITHUB_REMEDIATION_PR=false
INIT_MCP_ON_API=false

# Local dev: leave empty (no otel-collector on host)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Research module — auto scan + dashboard
ENABLE_RESEARCH_AUTO_SCAN=true
RESEARCH_AUTO_SCAN_HOURS=24
RESEARCH_DEFAULT_QUERY=latest technology industry news AI agents cloud infrastructure trends

# MCP config path (optional, defaults to backend/config/mcp_servers.json)
# MCP_CONFIG_PATH=

# --- MCP Server Credentials (set what you use) ---

# GitHub official MCP (@modelcontextprotocol/server-github)
GITHUB_TOKEN=
GITHUB_REPO=your-org/your-repo

# Optional: Brave Search (paid API) — disabled by default; use free DuckDuckGo search server
# BRAVE_API_KEY=

# Slack Ascent MCP (real Slack Web API)
SLACK_BOT_TOKEN=
SLACK_INCIDENT_CHANNEL=#incidents

# Kubernetes (kubectl + kubeconfig on host or in container)
K8S_NAMESPACE=production
K8S_DEPLOYMENT=payment-api
K8S_SCALE_REPLICAS=3
# K8S_DEBUG_POD=

# AWS CloudWatch (cloud MCP)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDWATCH_NAMESPACE=AWS/ApplicationELB
CLOUDWATCH_METRIC=TargetResponseTime

# Email SMTP — required for customer complaint replies
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=support@yourcompany.com
# Demo Northwind store (docker-compose demo-webapp) POSTs complaints to Ascent using ASCENT_API_BASE_URL → /api/v1/support/complaints; SMTP above sends the AI draft reply.
COMPANY_NAME=Your Company Support

# Health check URL for validation (fetch MCP)
HEALTH_CHECK_URL=

# Automatic incidents via Prometheus → Alertmanager (optional dev setup):
#   docker compose up -d postgres redis qdrant temporal temporal-ui prometheus alertmanager synthetic-probe
#   Then run API + worker via scripts/start.ps1 (API must listen on localhost:8000).
# Webhook URL is infrastructure/alertmanager/alertmanager.yml → /api/v1/webhooks/alertmanager
# Trigger: POST http://localhost:9109/simulate-error — alert fires ~30–90s later automatically.

# --- Demo web app (realistic E2E: browser → metrics → Prometheus → Alertmanager → Ascent) ---
#   docker compose up -d demo-webapp prometheus alertmanager
#   Open http://localhost:9110 → browse shop → add items → cart → Place order.
#   Expand bottom bar → Trip checkout → Place order fails + Prometheus fires → Ascent incident (~45–90s).
#   Click "Heal" to clear the alert; use /admin/heal same.
#   Complaints: http://localhost:9110/support → Ascent Support UI + SMTP reply email (configure SMTP_* above).

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
